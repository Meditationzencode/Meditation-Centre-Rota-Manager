# Copy this file to .env.local and fill in your Supabase project values.
# Find these in: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Only needed for admin user-creation and swap approvals (server-side only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Your app's public URL — used for password reset redirect links
# Local dev: http://localhost:3000  |  Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Resend API key for email notifications (signup confirmations, swap alerts)
# Sign up at https://resend.com — free tier covers 3,000 emails/month
# If omitted, email sending is silently skipped (the app still works fully)
RESEND_API_KEY=re_your_api_key_here

# Playwright e2e tests — set these to your demo account credentials
# All demo accounts use password: Demo1234!
PLAYWRIGHT_BASE_URL=http://localhost:3000
TEST_ADMIN_EMAIL=admin@bodhigrove.demo
TEST_ADMIN_PASSWORD=Demo1234!
TEST_VOL_EMAIL=vol1@bodhigrove.demo
TEST_VOL_PASSWORD=Demo1234!
# Viewer account — create a member with role=Viewer in Admin → Members, then set these:
TEST_VIEWER_EMAIL=viewer@bodhigrove.demo
TEST_VIEWER_PASSWORD=Demo1234!
